# Variabili d'ambiente richieste. Copia in `.env` e compila i valori.
# Su Vercel vanno impostate tutte e tre nelle Environment Variables del progetto.

# Connessione Postgres (con pooler, es. Supabase/Neon "pooled")
DATABASE_URL="postgresql://USER:PASSWORD@HOST:PORT/DB?schema=public"

# Connessione diretta (NON pooled) — richiesta da `prisma db push`/`migrate` in build
DIRECT_URL="postgresql://USER:PASSWORD@HOST:PORT/DB?schema=public"

# Password area manager (cookie di sessione). Default dev: turni2026
MANAGER_PASSWORD="turni2026"
