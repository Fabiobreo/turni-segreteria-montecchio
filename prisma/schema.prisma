// Schema dati — Gestione Turni Segreteria

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Secretary {
  id           String   @id @default(cuid())
  name         String
  contractType String // "fisso" | "a_chiamata"
  weeklyMax    Int      @default(0) // tetto ORE SETTIMANALI (0 = non impostato). Unico limite usato.
  color        String // chiave colore: mara | sonia | bea | emma | ari
  token        String   @unique
  active       Boolean  @default(true)
  sort         Int      @default(0)

  availabilities Availability[]
  shifts         Shift[]
}

model Availability {
  id          String   @id @default(cuid())
  secretary   Secretary @relation(fields: [secretaryId], references: [id], onDelete: Cascade)
  secretaryId String
  date        String // YYYY-MM-DD
  status      String // "disponibile" | "parziale" | "non_disponibile"
  slots       String? // JSON: [{"start":"HH:MM","end":"HH:MM"}, ...] — solo se parziale
  note        String?
  updatedAt   DateTime @updatedAt

  @@unique([secretaryId, date])
}

model Shift {
  id          String   @id @default(cuid())
  date        String // YYYY-MM-DD
  secretary   Secretary @relation(fields: [secretaryId], references: [id], onDelete: Cascade)
  secretaryId String
  start       String // HH:MM
  end         String // HH:MM
  impianto    String   @default("estivo") // "estivo" | "invernale"
  createdAt   DateTime @default(now())

  @@index([date])
  @@index([date, impianto])
}

model AuditLog {
  id      String   @id @default(cuid())
  at      DateTime @default(now())
  actor   String // chi ha fatto la modifica: nome segretaria o "Manager"
  entity  String // "availability" | "shift" | "secretary" | "impianto"
  action  String // "create" | "update" | "delete"
  summary String // descrizione leggibile della modifica
  date    String? // giorno interessato (YYYY-MM-DD), se applicabile
  before  String? // JSON dello stato precedente
  after   String? // JSON dello stato successivo

  @@index([at])
}

model Impianto {
  id           String  @id // "estivo" | "invernale"
  nome         String
  weekdayOpen  String  // HH:MM
  weekdayClose String  // HH:MM
  weekendOpen  String  // HH:MM
  weekendClose String  // HH:MM
  attivo       Boolean @default(true)
  sort         Int     @default(0)
}
